{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-gemini/gemini-3.1-flash-lite",
  "server": {
      "port": 4096,
  },
  "provider": {
    "google-gemini": {
      "npm": "@ai-sdk/google",
      "name": "Google Gemini",
      "options": {
        "apiKey": "$GEMINI_API_KEY"
      },
      "models": {
        "gemini-3.1-flash-lite": {
          "name": "$GEMINI_MODEL",
          "limit": {
            "context": 256000,
            "output": 4096
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
